name = "omnibot-app-update-worker"
main = "worker.js"
compatibility_date = "2026-05-12"

[[r2_buckets]]
binding = "APP_UPDATE_BUCKET"
bucket_name = "replace-with-your-r2-bucket-name"

[vars]
GITHUB_REPO = "omnimind-ai/OpenOmniBot"
DEFAULT_SOURCE = "worker"
R2_RELEASES_PREFIX = "releases"
R2_METADATA_PREFIX = "metadata/releases"

# Configure the admin token as a secret:
# wrangler secret put ADMIN_TOKEN
