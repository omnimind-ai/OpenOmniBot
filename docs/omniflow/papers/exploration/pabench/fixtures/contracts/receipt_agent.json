{
  "projectId": "bench-receipt-agent",
  "name": "Receipt Capture",
  "userIntent": "Capture expense receipts quickly from chat or image context.",
  "soulRules": [
    "The agent extracts vendor, amount, date, category, and note before writing a record.",
    "The HTML view shows the latest normalized records and a single capture action.",
    "Manual entry stays out of the primary HTML path for v1."
  ],
  "entity": {
    "name": "Receipt",
    "primaryAction": "Capture receipt"
  },
  "fields": [
    {
      "name": "title",
      "type": "string",
      "required": true
    },
    {
      "name": "amount",
      "type": "number"
    },
    {
      "name": "date",
      "type": "date"
    },
    {
      "name": "category",
      "type": "string"
    },
    {
      "name": "note",
      "type": "string"
    }
  ],
  "actions": [
    {
      "id": "receipt.capture",
      "executor": "agent",
      "displayName": "Capture receipt",
      "agentPrompt": "Read the user's receipt from chat text or image context, extract vendor, amount, date, category, and note, then call receipt.create with normalized fields.",
      "capabilities": [
        "chat_context",
        "image_understanding",
        "native.collection.create"
      ],
      "inputs": {}
    },
    {
      "id": "receipt.create",
      "executor": "native.collection.create",
      "displayName": "Save receipt",
      "inputs": {
        "title": "string",
        "amount": "number?",
        "date": "date?",
        "category": "string?",
        "note": "string?"
      }
    },
    {
      "id": "receipt.archive",
      "executor": "native.collection.archive",
      "displayName": "Archive",
      "inputs": {
        "item_id": "string"
      }
    },
    {
      "id": "receipt.list",
      "executor": "native.collection.list",
      "displayName": "List receipts",
      "inputs": {}
    }
  ],
  "views": {
    "primary": "Capture",
    "list": "Recent receipts",
    "empty": "Capture a receipt to create the first expense record."
  }
}
