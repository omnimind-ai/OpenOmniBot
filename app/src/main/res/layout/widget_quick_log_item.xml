<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/quick_log_widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/quick_log_widget_row_card"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/quick_log_widget_item_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="2dp"
        android:maxLines="2"
        android:textColor="#1E293B"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="end"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/quick_log_widget_item_edit_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/quick_log_widget_button_secondary"
            android:paddingLeft="12dp"
            android:paddingTop="7dp"
            android:paddingRight="12dp"
            android:paddingBottom="7dp">

            <TextView
                android:id="@+id/quick_log_widget_item_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quick_log_widget_edit"
                android:textColor="#334155"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/quick_log_widget_item_delete_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/quick_log_widget_button_secondary"
            android:paddingLeft="12dp"
            android:paddingTop="7dp"
            android:paddingRight="12dp"
            android:paddingBottom="7dp">

            <TextView
                android:id="@+id/quick_log_widget_item_delete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/quick_log_widget_delete"
                android:textColor="#B91C1C"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
