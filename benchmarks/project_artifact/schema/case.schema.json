{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pabench.dev/schema/project_artifact.case.v1.json",
  "title": "ProjectArtifactBench Case",
  "type": "object",
  "required": [
    "schema_version",
    "adapter",
    "id",
    "title",
    "category",
    "capabilities",
    "instruction",
    "input",
    "oracle"
  ],
  "properties": {
    "schema_version": {
      "const": "project_artifact.case.v1"
    },
    "adapter": {
      "type": "string",
      "minLength": 1,
      "description": "Runtime/checker adapter used by this case, for example oob_workbench."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_\\-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "create",
        "create_agent",
        "update",
        "debug",
        "export",
        "migration",
        "safety"
      ]
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "instruction": {
      "type": "string",
      "minLength": 1,
      "description": "Public task prompt given to the evaluated agent."
    },
    "input": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string"
        },
        "contract_fixture": {
          "type": "string"
        },
        "initial_project_fixture": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "oracle": {
      "type": "object",
      "description": "Checker specification. Public cases may expose simple checks; private test cases should hide hard oracle details.",
      "properties": {
        "static": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
