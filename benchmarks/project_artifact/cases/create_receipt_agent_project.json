{
  "schema_version": "project_artifact.case.v1",
  "adapter": "oob_workbench",
  "id": "create_receipt_agent_project",
  "title": "Create an agent-backed receipt capture Project",
  "category": "create_agent",
  "capabilities": [
    "agent_action_design",
    "capability_declaration",
    "native_writeback_design",
    "html_agent_trigger"
  ],
  "instruction": "Create a Workbench Project for collecting expense receipts. The primary action should trigger an agent flow that can read a receipt from chat or image context, normalize amount/date/vendor/category, and write the record through native collection storage. The HTML should show records and expose the agent trigger, not a large manual form.",
  "input": {
    "mode": "create",
    "contract_fixture": "../fixtures/contracts/receipt_agent.json"
  },
  "oracle": {
    "static": {
      "expected_project_id": "bench-receipt-agent",
      "agent_apis_require_capabilities": true,
      "required_files": [
        "project.json",
        "frontend/html/index.html",
        "PROJECT_CONTEXT.md"
      ],
      "required_docs": [
        "PROJECT_SOUL.md",
        "PROJECT_CONTEXT.md"
      ],
      "required_api_ids": [
        "receipt.capture",
        "receipt.create",
        "receipt.archive",
        "receipt.list"
      ],
      "required_html_substrings": [
        "window.oob.callApi('receipt.capture'",
        "btn-receipt-capture",
        "window.oob.onProjectUpdated("
      ],
      "forbidden_substrings": [
        "oob-project-distiller",
        "oob-project-designer",
        "oob-native-workbench"
      ],
      "forbidden_path_globs": [
        ".github/**",
        "AGENTS.md",
        "*.jks",
        ".env"
      ]
    }
  }
}
