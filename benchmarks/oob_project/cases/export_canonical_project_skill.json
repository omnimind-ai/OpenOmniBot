{
  "schema_version": "oob.project_benchmark_case.v1",
  "id": "export_canonical_project_skill",
  "title": "Export metadata records the canonical oob-project skill",
  "category": "export",
  "capabilities": [
    "export_contract_integrity",
    "canonical_skill_reference",
    "migration_regression_control"
  ],
  "instruction": "Export the existing notes Project. The export metadata must identify the canonical oob-project skill and must not revive retired Project skill ids.",
  "input": {
    "mode": "export",
    "initial_project_fixture": "../fixtures/projects/exportable_notes_v1"
  },
  "oracle": {
    "static": {
      "required_files": [
        "project.json",
        "export_manifest.json"
      ],
      "required_json_values": [
        {
          "file": "export_manifest.json",
          "pointer": "/source",
          "equals": "oob-project"
        },
        {
          "file": "export_manifest.json",
          "pointer": "/skills/0/skillId",
          "equals": "oob-project"
        },
        {
          "file": "export_manifest.json",
          "pointer": "/skills/0/path",
          "equals": "skills/oob-project/SKILL.md"
        }
      ],
      "forbidden_substrings": [
        "oob-project-distiller",
        "oob-project-designer",
        "oob-native-workbench"
      ],
      "forbidden_path_globs": [
        "skills/oob-project-distiller/**",
        "skills/oob-project-designer/**",
        "skills/oob-native-workbench/**",
        ".github/**",
        "*.jks",
        ".env"
      ]
    }
  }
}
