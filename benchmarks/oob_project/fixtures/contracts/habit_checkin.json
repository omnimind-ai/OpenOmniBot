{
  "projectId": "bench-habit-checkin",
  "name": "Habit Check-in",
  "userIntent": "Track a small set of daily habits and keep the main action fast.",
  "soulRules": [
    "Keep each habit as one native collection item.",
    "Checking in updates the existing item instead of creating a duplicate.",
    "Archived habits should not be shown as active habits."
  ],
  "entity": {
    "name": "Habit",
    "primaryAction": "Check in habit"
  },
  "fields": [
    {
      "name": "title",
      "type": "string",
      "required": true
    },
    {
      "name": "checkedToday",
      "type": "boolean"
    },
    {
      "name": "streak",
      "type": "integer"
    },
    {
      "name": "note",
      "type": "string"
    }
  ],
  "actions": [
    {
      "id": "habit.create",
      "executor": "native.collection.create",
      "displayName": "Add habit",
      "inputs": {
        "title": "string",
        "note": "string?",
        "checkedToday": "boolean?",
        "streak": "integer?"
      }
    },
    {
      "id": "habit.checkIn",
      "executor": "native.collection.update",
      "displayName": "Check in",
      "inputs": {
        "item_id": "string",
        "checkedToday": "boolean",
        "streak": "integer?"
      }
    },
    {
      "id": "habit.archive",
      "executor": "native.collection.archive",
      "displayName": "Archive",
      "inputs": {
        "item_id": "string"
      }
    },
    {
      "id": "habit.list",
      "executor": "native.collection.list",
      "displayName": "List habits",
      "inputs": {}
    }
  ],
  "views": {
    "primary": "Today",
    "list": "Active habits",
    "empty": "Add the first habit to start checking in."
  }
}
